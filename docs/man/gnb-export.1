.SH NAME
gnb-export - Export aliases and workflows to a file


.SH SYNOPSIS
\fBgnb export [names...] [flags]\fP


.SH DESCRIPTION
Export selected aliases and workflows to a config file.
If no names are specified, exports everything.
Example:
  gnb export --output backup.toml
  gnb export gs deploy --format yaml --output selected.yaml


.SH OPTIONS
\fB-f\fP, \fB--format\fP="toml"
	Output format (toml, yaml, json)

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for export

.PP
\fB-o\fP, \fB--output\fP=""
	Output file path (required)


.SH SEE ALSO
\fBgnb(1)\fP


