.SH NAME
gnb-add - Add a new alias


.SH SYNOPSIS
\fBgnb add   [flags]\fP


.SH DESCRIPTION
Add a new alias to the configuration.
Example:
  gnb add gs "git status -sb"
  gnb add ll "ls -la"
  gnb add --global gs "git status -sb"


.SH OPTIONS
\fB--global\fP[=false]
	Save to global config

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for add


